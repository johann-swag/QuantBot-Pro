# =============================================================
#  .env — API-Konfiguration (NIEMALS in Git committen!)
#
#  SICHERHEITS-REGELN:
#  1. Diese Datei MUSS in .gitignore stehen
#  2. API-Key darf NUR "Trade"-Berechtigung haben
#  3. Auszahlungs-Permission DEAKTIVIERT lassen
#  4. IP-Whitelist auf Exchange aktivieren (empfohlen)
#  5. Für Paper Trading: API-Keys LEER lassen
# =============================================================

# --- Binance API (leer lassen für Paper Trading!) ---
# Nur nötig für echten Live-Handel (python3 bot.py ohne --paper)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Telegram Notifications (optional aber empfohlen) ---
# Setup:
#   1. Telegram öffnen -> BotFather -> /newbot -> Token kopieren
#   2. Deinen neuen Bot anschreiben (einmal /start senden)
#   3. https://api.telegram.org/bot<TOKEN>/getUpdates aufrufen
#      -> "chat":{"id": XXXXX} ist deine Chat-ID
#   4. Test: python3 telegram_bot.py
TELEGRAM_TOKEN=dein_telegram_bot_token
TELEGRAM_CHAT_ID=deine_telegram_chat_id
